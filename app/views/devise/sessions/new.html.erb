<h2>ログイン</h2>

<%= form_with(url: session_path(resource_name), scope: resource_name, local: true) do |f| %>
  <div>
    <%= f.label :email, "メールアドレス" %><br>
    <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
  </div>

  <div>
    <%= f.submit "ログイン" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>