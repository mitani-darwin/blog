<h1>新規投稿作成</h1>

<%= form_with model: @post, local: true do |form| %>
  <div>
    <%= form.label :title, "タイトル" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :author, "書いた人" %>
    <%= form.text_field :author %>
  </div>

  <div>
    <%= form.label :content, "内容" %>
    <%= form.text_area :content %>
  </div>


  <div>
    <%= form.submit "投稿する" %>
  </div>
<% end %>